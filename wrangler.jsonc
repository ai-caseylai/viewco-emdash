{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "viewco-cms",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "viewco-cms-db",
			"database_id": "74112b7f-8a6b-49b5-9891-ea5888d8de3b",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "viewco-cms-media",
		},
	],
}
