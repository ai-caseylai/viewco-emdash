---
import { getEmDashEntry, getSeoMeta, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { detectLocale, SITE_TITLES } from "../../utils/i18n";

const locale = detectLocale(Astro.url.pathname);
const slug = decodeSlug(Astro.params.slug);
if (!slug) return Astro.redirect("/404");

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug, { locale });
if (!page) return Astro.redirect("/404");
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const siteTitle = SITE_TITLES[locale];
const seo = getSeoMeta(page, { siteTitle, siteUrl: Astro.url.origin, path: `/${slug}` });
---

<Base title={seo.title} pageTitle={seo.ogTitle} description={seo.description} canonical={seo.canonical} content={{ collection: "pages", id: page.data.id, slug }}>
  <section class="page-hero"><div class="container"><h1>{page.data.title}</h1></div></section>
  <section class="section"><div class="container"><div class="content-block"><PortableText value={page.data.content} /></div></div></section>

  {
    slug === "our-services" && (
      <div class="content-block" style="margin:2rem 1.5rem">
        <h2>Project Gallery</h2>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem">
          {["pexels-pat-whelen-2913248-5813016.jpg","pexels-kymbe-38-580928738-17013166-scaled.jpg","panorama-3323163_1920.jpg","Machine-1600x1200-1.jpg","oak-600-800.jpg","Viewco-website-HKSP-photo-wmremove.jpeg","Viewco-website-HKSP-photo-wmremove-1.jpeg","Viewco-website-bay-photo-wmremove.jpeg","Data-Record-6-scaled-e1736497744306.jpg","Inspection-1-scaled-e1736498471313-1024x683.jpg","IMG_1588-1290x725.jpg","IMG_1283-1290x725.jpg"].map(img => (
            <img src={"/"+img} alt={img} style="width:100%;height:300px;object-fit:cover;border-radius:8px;margin:4px" loading="lazy" />
          ))}
        </div>
      </div>
    )
  }
</Base>
