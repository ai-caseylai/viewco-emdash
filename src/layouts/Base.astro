---
import { getMenu, getSiteSettings } from "emdash";
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import { detectLocale, SITE_TITLES, SITE_TAGLINES, LOGO_ALTS } from "../utils/i18n";

interface Props {
  title: string;
  pageTitle?: string | null;
  description?: string | null;
  image?: string | null;
  canonical?: string | null;
  content?: { collection: string; id: string; slug?: string | null };
}

const { title, pageTitle, description, image, canonical, content } = Astro.props;
const locale = detectLocale(Astro.url.pathname);
const siteTitle = SITE_TITLES[locale];
const siteTagline = SITE_TAGLINES[locale];
const logoAlt = LOGO_ALTS[locale];

const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const pageDescription = description ?? siteTagline;

const menu = await getMenu("primary", { locale });

const pageCtx = createPublicPageContext({
  Astro,
  kind: content ? "content" : "custom",
  pageType: "website",
  title: fullTitle,
  pageTitle: pageTitle ?? title ?? siteTitle,
  description: pageDescription,
  canonical,
  image,
  content,
  siteName: siteTitle,
});

const homeUrl = locale === "zh-Hant" ? "/" : `/${locale === "zh-Hans" ? "cn" : "en"}/`;
---

<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={pageDescription} />
  <meta name="format-detection" content="telephone=no" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteTitle} />
  <title>{fullTitle}</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png" />
  <link rel="stylesheet" href="/viewco.css" />
  <EmDashHead page={pageCtx} />
</head>
<body>
  <EmDashBodyStart page={pageCtx} />

  <header class="header" id="header">
    <div class="header__inner container">
      <div class="header__left">
        <a href={homeUrl} class="header__logo">
          <img src="/logo-white.png" alt={logoAlt} width="183" height="49" />
          <img src="/logo-inverse.png" alt={logoAlt} width="183" height="49" style="display:none" class="logo-inverse" />
        </a>
        <nav class="header__nav" id="mainNav">
          <ul>
            
            {menu?.items?.map(item => (
              <li><a href={item.url} class={Astro.url.pathname === item.url ? "active" : ""}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
      <div class="header__right">
        <a href="/" class="lang-link">繁體</a>
        <a href="/cn/" class="lang-link">简体</a>
        <a href="/en/" class="lang-link">EN</a>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer__main container">
      <div class="footer__brand">
        <img src="/logo-white.png" alt={logoAlt} class="footer__logo" width="150" height="40" />
        <p class="footer__slogan">{siteTagline}</p>
      </div>
      <div class="footer__col">
        <h4 class="footer__heading">{locale === "en" ? "Home" : locale === "zh-Hans" ? "首页" : "首頁"}</h4>
        <nav>
          <a href={homeUrl}>Home</a>
          {menu?.items?.map(item => <a href={item.url}>{item.label}</a>)}
        </nav>
      </div>
      <div class="footer__col">
        <h4 class="footer__heading">{locale === "en" ? "Head Office" : locale === "zh-Hans" ? "总公司" : "總公司"}</h4>
        <address>
          <p>{locale === "en" ? "Unit 711-713, 7/F, Wing Fat Industrial Building, 12 Wang Tai Road, Kowloon Bay, Hong Kong" : locale === "zh-Hans" ? "中国香港 九龙 九龙湾宏泰道12号 荣发工业大厦7楼711-713室" : "中國香港 九龍 九龍灣宏泰道12號 榮發工業大廈7樓711-713室"}</p>
          <p><a href="mailto:engineering@viewco.com.hk">engineering@viewco.com.hk</a></p>
          <p><a href="tel:+85225430610">+852 25430610</a></p>
          <p><a href="https://wa.me/85290218198">WhatsApp: +852 90218198</a></p>
        </address>
      </div>
      <div class="footer__col">
        <h4 class="footer__heading">{locale === "en" ? "Social Media" : locale === "zh-Hans" ? "社交媒体" : "社交媒體"}</h4>
        <div class="footer__social-links">
          <a href="https://www.instagram.com/viewco.engineering/" target="_blank" rel="noopener" aria-label="Instagram" class="footer__social-link">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="mailto:engineering@viewco.com.hk" aria-label="Email" class="footer__social-link">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
          </a>
          <a href="https://wa.me/85290218198" target="_blank" rel="noopener" aria-label="WhatsApp" class="footer__social-link">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.5 14.5c-.3.8-1.3 1.5-2.2 1.5-1.2 0-2.5-.7-3.5-1.5s-1.8-2.2-1.8-3.5c0-.9.5-1.9 1.3-2.2.3-.1.5 0 .7.3l1 1.5c.2.2.2.6 0 .8l-.7.7c-.1.1-.1.3 0 .5.4.6 1 1.2 1.7 1.5.2.1.4 0 .5-.1l.7-.7c.2-.2.5-.2.8 0l1.5 1c.2.2.3.4.3.7z"/><path d="M20.5 12a8.5 8.5 0 1 1-3.2-6.8"/><path d="M12 3.5a8.5 8.5 0 0 1 8.5 8.5"/></svg>
          </a>
        </div>
        <img src="/awards.png" alt="Awards" class="footer__awards" width="120" height="80" loading="lazy" />
      </div>
    </div>
    <div class="footer__bottom">
      <div class="container">
        <p>&copy; 2026 {siteTitle} All Rights Reserved.</p>
      </div>
    </div>
  </footer>

  <EmDashBodyEnd page={pageCtx} />
</body>
</html>
