	<script>
document.addEventListener('DOMContentLoaded', function() {
    // Get current URL and base URL
    const currentUrl = window.location.href;
    const baseUrl = "https://viewco.com.hk"; // window.location.origin;
    const currentPath = currentUrl.replace( baseUrl,''); // window.location.pathname;
	// alert( currentPath );
    
    // Helper function to create language URLs
    const createLangUrl = (langCode) => {
        // If already in this language, return current URL
        if (currentPath.startsWith('/${langCode}/')) {
            return currentUrl;
        }
        
        // If in another language, replace the language code
        if (currentPath.startsWith('/en/') ) {
            return currentUrl.replace('/en/', '/'+ langCode + '/');
        } else if ( currentPath.startsWith('/cn/') ) {
            return currentUrl.replace('/cn/', '/'+ langCode + '/');
        }
        
        // If no language code, insert the new one
        return `${baseUrl}/${langCode}/${currentPath}`;
    };
    
    // Update Traditional Chinese link (URL2HK - remove language code)
    const url2hk = document.querySelector('.URL2HK a');
    if (url2hk) {
        if (currentPath.startsWith('/en/') || currentPath.startsWith('/cn/')) {
            url2hk.href = currentUrl.replace(/\/(en|cn)\//, '/');
        } else {
            url2hk.href = currentUrl; // Already in Traditional Chinese
        }
    }
    
    // Update Simplified Chinese link (URL2CN)
    const url2cn = document.querySelector('.URL2CN a');
    if (url2cn) {
        url2cn.href = createLangUrl('cn');
    }
    
    // Update English link (URL2EN)
    const url2en = document.querySelector('.URL2EN a');
    if (url2en) {
        url2en.href = createLangUrl('en');
    }
    
    // Add active class to current language
    if (currentPath.startsWith('/en/')) {
        // document.querySelector('.URL2EN a')?.classList.add('current-language');
        document.querySelector('.URL2EN')?.classList.add('hidden');
    } else if (currentPath.startsWith('/cn/')) {
        // document.querySelector('.URL2CN a')?.classList.add('current-language');
        document.querySelector('.URL2CN')?.classList.add('hidden');
    } else {
        // document.querySelector('.URL2HK a')?.classList.add('current-language');
        document.querySelector('.URL2HK')?.classList.add('hidden');
    }
});
	</script>

</body>
</html>